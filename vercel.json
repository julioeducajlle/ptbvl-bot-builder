{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": "react",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "bundle.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/bundle.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
